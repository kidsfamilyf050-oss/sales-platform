generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SuperAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Company {
  id               String    @id @default(cuid())
  name             String
  businessSphere   String?
  reportingStart   Int       @default(1)
  isActive         Boolean   @default(true)
  subscriptionPlan String?   // "trial", "starter", "pro"
  trialEndsAt      DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  departments   Department[]
  users         User[]
  plans         Plan[]
  notifications Notification[]
  salesChannels SalesChannel[]
  leads         Lead[]
}

model Department {
  id        String         @id @default(cuid())
  name      String
  type      DepartmentType
  hasLiders Boolean        @default(false)
  companyId String
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  users   User[]
  plans   Plan[]
  reports Report[]
}

enum DepartmentType {
  SALES
  MARKETING
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String
  phone        String?
  passwordHash String?
  role         UserRole
  managerType  ManagerType?
  status       UserStatus  @default(ACTIVE)
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  inviteToken  String?     @unique
  invitedAt    DateTime?
  lastLoginAt  DateTime?
  lastSeenAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  reports           Report[]
  sales             Sale[]
  dealLinks         DealLink[]
  notifications     Notification[]
  planChanges       PlanChange[]
  sessions          UserSession[]
  leadsCreated      Lead[]      @relation("LeadCreatedBy")
  leadsAssigned     Lead[]      @relation("LeadAssignedTo")
  leadTasksAssigned LeadTask[]  @relation("LeadTaskAssignee")
  leadTasksCreated  LeadTask[]  @relation("LeadTaskCreator")
}

model UserSession {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  loginAt    DateTime  @default(now())
  logoutAt   DateTime?
  duration   Int?      // seconds
  ipAddress  String?
  userAgent  String?
}

enum UserRole {
  OWNER
  ROP
  MANAGER
  MARKETER
}

enum ManagerType {
  LIDER
  CLOSER
}

enum UserStatus {
  ACTIVE
  ARCHIVED
}

model Plan {
  id           String   @id @default(cuid())
  period       String   // "2024-01"
  type         PlanType
  value        Float
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  userId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  changes PlanChange[]

  @@unique([period, type, companyId, departmentId, userId])
}

enum PlanType {
  SALES_AMOUNT
  SALES_COUNT
  AVG_CHECK
  CONVERSION
  LEADS
  QUALIFIED_LEADS
  MEETINGS_SCHEDULED
  MEETINGS_ATTENDED
  BUDGET
}

model PlanChange {
  id        String   @id @default(cuid())
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  oldValue  Float
  newValue  Float
  createdAt DateTime @default(now())
}

model Report {
  id           String     @id @default(cuid())
  date         DateTime
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  type         ReportType
  data         Json
  comment      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([date, userId, type])
}

enum ReportType {
  LIDER
  CLOSER
  MARKETER
}

// Individual sale entries — added throughout the day, separate from daily stats report
model Sale {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId     String
  date          String   // YYYY-MM-DD local date
  amount        Float
  paymentType   String   // 'new_sale' | 'additional'
  paymentMethod String   // 'cash' | 'card' | 'credit' | 'installment'
  bank          String?
  months        Int?
  crmLink       String?
  comment       String?
  leadId        String?  @unique  // if created from a Lead (prevents duplicates)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, date])
  @@index([companyId, date])
}

// CRM links for refusals and in-work deals tracked by closer
model DealLink {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  type      String   // 'REFUSAL' | 'IN_WORK'
  link      String
  note      String?
  date      String   // YYYY-MM-DD
  createdAt DateTime @default(now())

  @@index([userId, date])
  @@index([companyId, type, date])
}

model Notification {
  id        String           @id @default(cuid())
  companyId String
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
}

enum NotificationType {
  REPORT_MISSING
  PLAN_CRITICAL
  CONVERSION_DROP
  BUDGET_EXCEEDED
  LEADS_LOW
  LEAD_COST_HIGH
}

// ── Sales Channels ────────────────────────────────────────────────────────────
model SalesChannel {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())

  leads Lead[]

  @@index([companyId])
}

// ── Lead management ───────────────────────────────────────────────────────────
enum LeadStatus {
  NEW          // qualified, not yet assigned to closer
  ASSIGNED     // assigned to closer, waiting for accept
  IN_WORK      // closer accepted
  REFUSED      // closer refused
  SOLD         // converted to sale
  UNQUALIFIED  // not qualified
}

model Lead {
  id             String        @id @default(cuid())
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User          @relation("LeadCreatedBy", fields: [createdById], references: [id])
  assignedToId   String?
  assignedTo     User?         @relation("LeadAssignedTo", fields: [assignedToId], references: [id])

  // Client info
  clientName     String
  phone          String
  date           String        // YYYY-MM-DD

  // Classification
  salesChannelId String?
  salesChannel   SalesChannel? @relation(fields: [salesChannelId], references: [id])
  isQualified    Boolean       @default(true)
  isScheduled    Boolean       @default(false)
  comment        String?       // lider's comment

  // Status
  status         LeadStatus    @default(NEW)

  // Closer fields (filled when processing)
  amount         Float?
  paymentType    String?       // 'new_sale' | 'additional'
  paymentMethod  String?       // 'cash' | 'card' | 'credit' | 'installment'
  bank           String?
  months         Int?
  crmLink        String?
  closerComment  String?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tasks          LeadTask[]

  @@index([companyId, status])
  @@index([createdById, date])
  @@index([assignedToId, status])
}

model LeadTask {
  id          String   @id @default(cuid())
  leadId      String?                                                                              // optional: null = standalone task
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String                                                                               // assigned to
  user        User     @relation("LeadTaskAssignee", fields: [userId], references: [id], onDelete: Cascade)
  createdById String?                                                                              // null = self, else ROP/OWNER who assigned
  createdBy   User?    @relation("LeadTaskCreator", fields: [createdById], references: [id])
  title       String
  dueDate     String   // YYYY-MM-DD
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, completed])
  @@index([leadId])
  @@index([createdById])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // e.g. "COMPANY_PLAN_CHANGED", "USER_BLOCKED", "USER_ROLE_CHANGED"
  description String
  adminEmail  String?
  targetId    String?
  targetType  String?  // "company" | "user"
  oldValue    String?
  newValue    String?
  companyId   String?
  companyName String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([companyId])
}
